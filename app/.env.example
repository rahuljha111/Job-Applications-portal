# Docker Compose / backend production variables
POSTGRES_DB=jobportal1
DB_USERNAME=postgres
DB_PASSWORD=change-me
JWT_SECRET=change-me-in-production-minimum-32-chars
MAIL_HOST=smtp.gmail.com
